# Copy this file to `.env` and adjust. Real environment variables override these values.
# The server reads `.env` from the working directory (or DOTENV_PATH if set).

# HTTP bind address and port.
HOST=0.0.0.0
PORT=8080

# Optional shared secret guarding the RPC routes.
# - If set (non-blank): every request to /rpc/* must present this secret via the
#   `X-Access-Secret` header, an `Authorization: Bearer <secret>` header, or an
#   `access_secret` query parameter — otherwise the server responds with HTTP 403.
# - If left blank or removed: access is open and any secret sent by a client is ignored.
ACCESS_SECRET=

# Allow clients to pass {"path": "/absolute/path"} instead of sending file contents inline.
# Useful when the server runs locally and serializing large model directories is slow.
# WARNING: enabling this lets any authenticated caller read arbitrary paths on the server filesystem.
# Leave false (default) when the server is exposed on a network.
LOCAL_FILES_DISCOVERY=false
